# Copy to .env and fill in from Supabase Dashboard → Project Settings → API
# Project: Geshtenja (https://supabase.com/dashboard)

# Frontend (Vite)
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_or_publishable_key_here

# Edge Function: send-order-email (Supabase Dashboard → Edge Functions → Secrets)
# Sends you an email on every new order and cancellation with customer contact details.
# RESEND_API_KEY=re_...
# ADMIN_ORDER_EMAIL=your-email@example.com
# ORDER_FROM_EMAIL=Geshtenja <orders@geshtenja.com>   # optional; must be a verified Resend domain

# One-time migration only (from Dashboard → Settings → Database → Database password)
# SUPABASE_DB_PASSWORD=your_database_password

# Alternative migration via Management API (Dashboard → Account → Access Tokens)
# SUPABASE_ACCESS_TOKEN=sbp_...
